      }
    },
    "android": {
      "package": "com.rdllegalpro.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {},
    "scheme": "rdllegalproexpo",
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/auth"
    ],
    "extra": {
      "eas": {
        "projectId": "4dc5482f-2722-4859-82ad-873c30a15e85"
      }
    }
  }
}
