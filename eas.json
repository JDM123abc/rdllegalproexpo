{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "latest"
      }
    },
"preview": {
  "distribution": "internal",
  "android": {
    "buildType": "apk",
    "image": "latest"
  },
  "env": {
    "GOOGLE_SERVICES_JSON": "$ANDROID_GOOGLE_SERVICES"
  }
},
"production": {
  "autoIncrement": true,
  "android": {
    "buildType": "apk",
    "image": "latest"
  },
  "env": {
    "GOOGLE_SERVICES_JSON": "$ANDROID_GOOGLE_SERVICES"
  }
}
  },
  "submit": {
    "production": {}
  }
}
